{
    "ver": "1.0.0",
    "authors": ["ac.shahnam"],
    "contact": "help@kbase.us",
    "visible": true,
    "categories": ["active", "assembly"],
    "widgets": {
        "input": null,
        "output": "no-display"
    },
    "parameters": [
        {
            "id": "reads_ref",
            "optional": false,
            "advanced": false,
            "allow_multiple": false,
            "default_values": [""],
            "field_type": "text",
            "text_options": {
                "valid_ws_types": [
                    "KBaseSets.ReadsSet",
                    "KBaseFile.SingleEndLibrary",
                    "KBaseFile.PairedEndLibrary",
                    "KBaseAssembly.SingleEndLibrary",
                    "KBaseAssembly.PairedEndLibrary"
                ],
                "target_type_transform": "resolved-ref"
            }
        },
        {
            "id": "read_type",
            "optional": false,
            "advanced": false,
            "allow_multiple": false,
            "default_values": ["nanopore"],
            "field_type": "dropdown",
            "dropdown_options": {
                "options": [
                    {
                        "value": "nanopore",
                        "display": "Oxford Nanopore (raw)",
                        "id": "nanopore"
                    },
                    {
                        "value": "pacbio-hifi",
                        "display": "PacBio HiFi / CCS (pacbio-hifi)",
                        "id": "pacbio-hifi"
                    },
                    {
                        "value": "pacbio-raw",
                        "display": "PacBio CLR (pacbio-raw)",
                        "id": "pacbio-raw"
                    }
                ]
            }
        },
        {
            "id": "genome_size",
            "optional": false,
            "advanced": false,
            "allow_multiple": false,
            "default_values": ["5m"],
            "field_type": "text",
            "text_options": {
                "validate_as": "string",
                "regexp": [
                    {
                        "regex": "^[0-9]+(\\.[0-9]+)?[kmgKMG]?$",
                        "error_text": "Must be a number with optional suffix k, m, or g (e.g. 5m, 2.4g, 500k)"
                    }
                ]
            }
        },
        {
            "id": "output_assembly_name",
            "optional": false,
            "advanced": false,
            "allow_multiple": false,
            "default_values": ["Canu_Assembly"],
            "field_type": "text",
            "text_options": {
                "validate_as": "WorkspaceName",
                "is_output_name": true,
                "placeholder": "Canu_Assembly"
            }
        },
        {
            "id": "min_read_length",
            "optional": true,
            "advanced": false,
            "allow_multiple": false,
            "default_values": ["1000"],
            "field_type": "text",
            "text_options": {
                "validate_as": "int",
                "min_integer": "100",
                "max_integer": "100000"
            }
        },
        {
            "id": "corrected_error_rate",
            "optional": true,
            "advanced": false,
            "allow_multiple": false,
            "default_values": [""],
            "field_type": "text",
            "text_options": {
                "validate_as": "float",
                "min_float": "0.001",
                "max_float": "0.5",
                "placeholder": "0.045 (PacBio) / 0.144 (Nanopore)"
            }
        },
        {
            "id": "min_overlap_length",
            "optional": true,
            "advanced": true,
            "allow_multiple": false,
            "default_values": ["500"],
            "field_type": "text",
            "text_options": {
                "validate_as": "int",
                "min_integer": "50",
                "max_integer": "10000"
            }
        },
        {
            "id": "max_input_coverage",
            "optional": true,
            "advanced": true,
            "allow_multiple": false,
            "default_values": ["0"],
            "field_type": "text",
            "text_options": {
                "validate_as": "int",
                "min_integer": "0",
                "max_integer": "10000",
                "placeholder": "0 (use all reads)"
            }
        },
        {
            "id": "cor_out_coverage",
            "optional": true,
            "advanced": true,
            "allow_multiple": false,
            "default_values": ["40"],
            "field_type": "text",
            "text_options": {
                "validate_as": "int",
                "min_integer": "0",
                "max_integer": "10000"
            }
        },
        {
            "id": "fast_assembly",
            "optional": true,
            "advanced": true,
            "allow_multiple": false,
            "default_values": ["0"],
            "field_type": "checkbox",
            "checkbox_options": {
                "checked_value": 1,
                "unchecked_value": 0
            }
        }
    ],
    "behavior": {
        "service-mapping": {
            "url": "",
            "name": "kb_canu",
            "method": "run_kb_canu",
            "input_mapping": [
                {
                    "narrative_system_variable": "workspace",
                    "target_property": "workspace_name"
                },
                {
                    "input_parameter": "reads_ref",
                    "target_property": "reads_ref"
                },
                {
                    "input_parameter": "read_type",
                    "target_property": "read_type"
                },
                {
                    "input_parameter": "genome_size",
                    "target_property": "genome_size"
                },
                {
                    "input_parameter": "output_assembly_name",
                    "target_property": "output_assembly_name"
                },
                {
                    "input_parameter": "min_read_length",
                    "target_property": "min_read_length",
                    "target_type_transform": "int"
                },
                {
                    "input_parameter": "corrected_error_rate",
                    "target_property": "corrected_error_rate",
                    "target_type_transform": "none"
                },
                {
                    "input_parameter": "min_overlap_length",
                    "target_property": "min_overlap_length",
                    "target_type_transform": "int"
                },
                {
                    "input_parameter": "max_input_coverage",
                    "target_property": "max_input_coverage",
                    "target_type_transform": "int"
                },
                {
                    "input_parameter": "cor_out_coverage",
                    "target_property": "cor_out_coverage",
                    "target_type_transform": "int"
                },
                {
                    "input_parameter": "fast_assembly",
                    "target_property": "fast_assembly",
                    "target_type_transform": "int"
                }
            ],
            "output_mapping": [
                {
                    "service_method_output_path": [0, "report_name"],
                    "target_property": "report_name"
                },
                {
                    "service_method_output_path": [0, "report_ref"],
                    "target_property": "report_ref"
                },
                {
                    "constant_value": "kb_canu",
                    "target_property": "report_module"
                }
            ]
        }
    },
    "job_id_output_field": "docker"
}
